# Copy this file to .env.local and fill in your key.
# Get a key at https://console.groq.com  -> never commit the real key.
GROQ_API_KEY=your_groq_api_key_here

# Which Groq model the chatbot uses. 8b-instant = fast + cheap (default).
# Swap to llama-3.3-70b-versatile for richer answers.
CHAT_MODEL=llama-3.1-8b-instant
